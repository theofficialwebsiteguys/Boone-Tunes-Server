NODE_ENV=development
PORT=3001
AUTO_MIGRATE=true   # set to false to disable auto-migration on server start

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Option A: full connection URL (used in production / Heroku)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B: individual credentials (used locally)
DB_NAME=boone_tunes_dev
DB_USER=postgres
DB_PASS=pass
DB_HOST=localhost
DB_PORT=5432

# ── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── YouTube ──────────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com — enable YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key
# Future OAuth (do not fill in until user-level YouTube auth is implemented)
# YOUTUBE_CLIENT_ID=your_youtube_client_id
# YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
